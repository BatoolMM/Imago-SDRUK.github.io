{
	"name": "data_catalogue",
	"version": "3.0.16",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5174 --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:generate": "drizzle-kit generate",
		"db:sync": "DB_MIGRATING=true drizzle-kit introspect",
		"db:migrate": "DB_MIGRATING=true drizzle-kit migrate",
		"db:drop": "DB_MIGRATING=true drizzle-kit drop",
		"db:seed": "",
		"db:push": "drizzle-kit push"
	},
	"devDependencies": {
		"@arturoguzman/art-ui": "^2.9.1",
		"@azure/storage-blob": "^12.32.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@imago/config": "workspace:*",
		"@imago/ui": "workspace:*",
		"@ory/client-fetch": "^1.22.37",
		"@ory/keto-namespace-types": "0.13.0-alpha.0",
		"@playwright/test": "^1.60.0",
		"@rollup/plugin-json": "^6.1.0",
		"@sentry/sveltekit": "^10.56.0",
		"@sindresorhus/slugify": "^3.0.0",
		"@svar-ui/svelte-grid": "^2.7.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/luxon": "^3.7.1",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"@vitest/browser": "^4.1.8",
		"arktype": "^2.2.0",
		"dompurify": "^3.4.8",
		"dotenv": "^17.4.2",
		"drizzle-arktype": "^0.1.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"fractional-indexing": "^3.2.0",
		"globals": "^17.6.0",
		"jsonwebtoken": "^9.0.3",
		"luxon": "^3.7.2",
		"marked": "^16.4.2",
		"nanoid": "^5.1.11",
		"pg": "^8.21.0",
		"pg-native": "^3.8.0",
		"pino": "^10.3.1",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"rollup-plugin-import-css": "^4.2.1",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"typescript-svelte-plugin": "^0.3.52",
		"uuid": "^14.0.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	}
